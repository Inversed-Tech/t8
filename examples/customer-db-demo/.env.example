# Customer-DB demo env. Copy to .env (demo.sh does this for you) and add your key.
# KEEP .env OUT OF GIT — it is gitignored here for that reason.

# REQUIRED: your Anthropic API key. It lives ONLY here, inside T8's config — the agent
# reaches the model THROUGH T8 and never holds it. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Demo-only fake "database credential" the agent must never hold (T8 injects it). Any value works.
DEMO_DB_KEY=db_live_REAL_secret_held_only_by_t8_9f3a7c

# Demo-only deterministic CA seed (keeps the local demo CA stable across restarts).
# Regenerate with:  openssl rand -hex 32   — do NOT reuse this for anything real.
T8_CA_SEED=4f1c0e8a7b6d5c4e3a2b1f0e9d8c7b6a5f4e3d2c1b0a9f8e7d6c5b4a3f2e1d0c

# Demo runs on 18020 to avoid colliding with a primary T8 on 1800.
T8_PORT=18020

# ADMIN KNOBS — changed live via ./admin.sh. Defaults below.
ALLOWED_CUSTOMER_RANGE=42
ALLOWED_HOSTS=mock-db,api.anthropic.com
DB_WRITES_ALLOWED=false
